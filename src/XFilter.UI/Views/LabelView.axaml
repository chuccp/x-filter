<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.LabelView"
             x:DataType="vm:LabelViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="🏷" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource label.title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="{DynamicResource label.filter_unlabeled}" Command="{Binding SetFilterCommand}" CommandParameter="unlabeled"
                            Classes="Small Primary"/>
                    <Button Content="{DynamicResource label.filter_all}" Command="{Binding SetFilterCommand}" CommandParameter="all"
                            Classes="Small Outline"/>
                    <Button Content="{DynamicResource label.filter_spam}" Command="{Binding SetFilterCommand}" CommandParameter="spam"
                            Classes="Small Outline"/>
                    <Button Content="{DynamicResource label.filter_normal}" Command="{Binding SetFilterCommand}" CommandParameter="not-spam"
                            Classes="Small Outline"/>
                </StackPanel>
                <SelectableTextBlock Text="{Binding StatsText}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Border>

        <Border Classes="Card" IsVisible="{Binding HasComments}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SelectableTextBlock Text="{Binding IndexText}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    <SelectableTextBlock Text="{Binding CommentUser}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <SelectableTextBlock Text="{Binding PostText}" FontSize="11" Foreground="{StaticResource TextHint}" TextWrapping="Wrap"/>
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <SelectableTextBlock Text="{Binding CommentText}" FontSize="14" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource label.btn_prev}" Command="{Binding PrevCommand}"
                            Classes="Outline" Width="100"/>
                    <Button Content="{DynamicResource label.btn_skip}" Command="{Binding NextCommand}"
                            Classes="Primary" Width="100"/>
                    <Button Content="{DynamicResource label.btn_spam}" Command="{Binding SpamCommand}"
                            Classes="Danger" Width="90"/>
                    <Button Content="{DynamicResource label.btn_not_spam}" Command="{Binding NotSpamCommand}"
                            Classes="Success" Width="90"/>
                    <Button Content="{DynamicResource label.btn_delete}" Command="{Binding DeleteCommand}"
                            Classes="Outline" Width="60"/>
                </StackPanel>
                <SelectableTextBlock Text="{DynamicResource label.shortcuts}" FontSize="10" Foreground="{StaticResource TextHint}"/>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center"/>
                <SelectableTextBlock Text="{DynamicResource label.batch_title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="{DynamicResource label.batch_all_spam}" Command="{Binding BatchSpamCommand}"
                        Classes="Small Danger" Width="120"/>
                <Button Content="{DynamicResource label.batch_all_not_spam}" Command="{Binding BatchNotSpamCommand}"
                        Classes="Small Success" Width="120"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
