<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.BlocklistView"
             x:DataType="vm:BlocklistViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="📋" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource blocklist.title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <SelectableTextBlock FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Text="{Binding CountText}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding AddInput}" Watermark="{DynamicResource blocklist.modal_add_placeholder}" Width="140"/>
                    <Button Content="{DynamicResource blocklist.btn_add}" Command="{Binding AddCommand}"
                            Classes="Small Primary"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0">
                    <Button Content="{DynamicResource blocklist.btn_import}" Command="{Binding ImportCommand}"
                            Classes="Small Outline"/>
                    <Button Content="{DynamicResource blocklist.btn_clear}" Command="{Binding ClearCommand}"
                            Classes="Small Danger"/>
                    <TextBox Text="{Binding ImportText}" Watermark="{DynamicResource blocklist.modal_import_placeholder}" Width="140" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding BlockUrl}" Watermark="{DynamicResource blocklist.modal_block_url_placeholder}" Width="180" FontSize="11"/>
                    <Button Content="{DynamicResource blocklist.btn_block}" Command="{Binding StartBlockCommand}"
                            Classes="Small Danger"
                            IsEnabled="{Binding IsRunning, Converter={x:Static conv:AppConverters.Not}}"/>
                    <Button Content="{DynamicResource common.cancel}" Command="{Binding CancelBlockCommand}"
                            Classes="Small Outline"
                            IsVisible="{Binding IsRunning}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{StaticResource CardBg}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MinHeight="200">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <SelectableTextBlock Grid.Column="0" Text="{Binding Username}"
                                               FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="4,1" Margin="0,0,6,0"
                                            Background="{Binding IsBlocked, Converter={x:Static conv:AppConverters.BlockedBadge}}">
                                        <TextBlock Text="{Binding IsBlocked, Converter={x:Static conv:AppConverters.BlockedText}}"
                                                   FontSize="10" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <SelectableTextBlock Text="{Binding Status}" Classes="StatusText"/>
        <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                MaxHeight="150" IsVisible="{Binding IsRunning}">
            <ScrollViewer>
                <SelectableTextBlock Text="{Binding Log}" Classes="LogText" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
