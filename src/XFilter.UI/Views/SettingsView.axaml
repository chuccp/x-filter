<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             x:Class="XFilter.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Spacing="16">
        <Border Background="#ffffff" CornerRadius="10" Padding="20" BorderBrush="#e2e8f0" BorderThickness="1">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⚙" FontSize="16"/>
                    <TextBlock Text="{DynamicResource settings.title}" FontSize="16" FontWeight="Bold" Foreground="#0f172a"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource settings.scroll_label}" FontSize="12" Foreground="#64748b"/>
                    <TextBox Text="{Binding MaxScroll}" Width="120"
                             Background="#f8fafc" Foreground="#0f172a" BorderBrush="#e2e8f0"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource settings.scroll_delay_label}" FontSize="12" Foreground="#64748b"/>
                    <TextBox Text="{Binding ScrollDelay}" Width="120"
                             Background="#f8fafc" Foreground="#0f172a" BorderBrush="#e2e8f0"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{DynamicResource settings.threshold_label}" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding SpamThreshold}" FontSize="12" FontWeight="Bold" Foreground="#0f172a"/>
                    </StackPanel>
                    <Slider Value="{Binding SpamThreshold}" Minimum="0.5" Maximum="0.95"
                            TickFrequency="0.05" Width="250"/>
                </StackPanel>
                <Button Content="{DynamicResource settings.btn_save}" Command="{Binding SaveCommand}" Width="100" Height="34"
                        Background="#3b82f6" Foreground="White" FontSize="13" CornerRadius="6"/>
                <TextBlock Text="{Binding SaveStatus}" FontSize="12" Foreground="#10b981"/>
            </StackPanel>
        </Border>

        <Border Background="#ffffff" CornerRadius="10" Padding="20" BorderBrush="#e2e8f0" BorderThickness="1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🧠" FontSize="14"/>
                    <TextBlock Text="{DynamicResource settings.model_title}" FontSize="14" FontWeight="Bold" Foreground="#0f172a"/>
                </StackPanel>
                <TextBlock Text="{Binding ModelInfo}" FontSize="12" Foreground="#475569"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{DynamicResource download.repo_label}" FontSize="12" Foreground="#64748b" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding DownloadRepo}" Width="200" Height="30"
                             Background="#f8fafc" Foreground="#0f172a" BorderBrush="#e2e8f0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource settings.btn_download_model}" Command="{Binding DownloadModelCommand}" Width="80" Height="30"
                            Background="#3b82f6" Foreground="White" FontSize="12" CornerRadius="4"/>
                    <Button Content="{DynamicResource settings.btn_load_model}" Command="{Binding LoadModelCommand}" Width="80" Height="30"
                            Background="#10b981" Foreground="White" FontSize="12" CornerRadius="4"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
