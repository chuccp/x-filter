<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
        xmlns:conv="clr-namespace:XFilter.UI.Converters"
        x:Class="XFilter.UI.Views.DownloadModelWindow"
        Title="{Binding WindowTitle}" Width="520" Height="460"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBg}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="24,20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
            <TextBlock Text="🧠" FontSize="18"/>
            <SelectableTextBlock Text="{Binding WindowTitle}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10"
                        IsVisible="{Binding HasStarted, Converter={x:Static conv:AppConverters.Not}}">
                <SelectableTextBlock Text="{Binding RepoLabel}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                <TextBox Text="{Binding Repo}" FontSize="12" Height="32"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,8"
                        IsVisible="{Binding HasStarted}">
                <TextBox Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" FontSize="12"
                         Background="Transparent" BorderThickness="0" IsReadOnly="True"
                         TextWrapping="Wrap"/>
                <StackPanel Spacing="4" IsVisible="{Binding IsDownloading}">
                    <ProgressBar Value="{Binding Percent}" Minimum="0" Maximum="100"
                                 Height="4" Foreground="{StaticResource AccentColor}" Background="{StaticResource BorderColor}"
                                 CornerRadius="2"/>
                    <SelectableTextBlock Text="{Binding CurrentFile}" Foreground="{StaticResource TextHint}" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>

            <SelectableTextBlock Grid.Row="1" Text="{Binding Status}" Classes="StatusText"
                       IsVisible="{Binding HasStarted, Converter={x:Static conv:AppConverters.Not}}"/>

            <ScrollViewer Grid.Row="2" IsVisible="{Binding HasStarted}">
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:FileItem">
                            <Border Padding="6,4" Margin="0,1"
                                    Background="{StaticResource CardBg}" CornerRadius="4"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                Margin="0,0,0,2">
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" Width="20"/>
                                        <SelectableTextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SizeDisplay}"
                                               FontSize="10" Foreground="{StaticResource TextHint}" VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                 Value="{Binding Percent}" Minimum="0" Maximum="100"
                                                 Height="4" Foreground="{StaticResource SuccessColor}" Background="Transparent"
                                                 Margin="26,2,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <SelectableTextBlock Grid.Row="2" Text="{Binding ErrorHint}" Classes="ErrorText"
                   IsVisible="{Binding HasError}" Margin="0,8"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                    VerticalAlignment="Bottom">
            <Button Content="{Binding StartButton}" Command="{Binding StartDownloadCommand}"
                    IsVisible="{Binding HasStarted, Converter={x:Static conv:AppConverters.Not}}"
                    Classes="Primary"/>
            <Button Content="{Binding CancelButton}" Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsDownloading}"
                    Classes="Outline"/>
            <Button Content="{Binding ConfirmButton}" Command="{Binding ConfirmCommand}"
                    IsEnabled="{Binding IsComplete}"
                    Classes="Success"/>
        </StackPanel>
    </Grid>
</Window>
