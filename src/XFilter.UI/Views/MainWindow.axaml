<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
        xmlns:views="clr-namespace:XFilter.UI.Views"
        xmlns:conv="clr-namespace:XFilter.UI.Converters"
        x:Class="XFilter.UI.Views.MainWindow"
        x:Name="Root"
        Title="x-filter — X Spam Filter"
        Width="940" Height="720"
        MinWidth="840" MinHeight="600"
        Background="{StaticResource PageBg}">
    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="230,*">
        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
                <!-- Brand -->
                <StackPanel Grid.Row="0" Margin="4,4,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{StaticResource AccentColor}" CornerRadius="8"
                                Width="32" Height="32">
                            <TextBlock Text="🛡" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="x-filter" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="{DynamicResource app.subtitle}" FontSize="11"
                                       Foreground="{StaticResource TextHint}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Role Toggle -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBg}"
                        CornerRadius="8" Padding="3" Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,*">
                        <Border Grid.Column="0" CornerRadius="6" Padding="6,5"
                                Background="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleBg}, ConverterParameter=admin}"
                                Cursor="Hand"
                                PointerPressed="RoleToggle_Click" Tag="admin">
                            <TextBlock Text="{DynamicResource app.role_admin}" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleFg}, ConverterParameter=admin}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="6" Padding="6,5" Margin="2,0,0,0"
                                Background="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleBg}, ConverterParameter=user}"
                                Cursor="Hand"
                                PointerPressed="RoleToggle_Click" Tag="user">
                            <TextBlock Text="{DynamicResource app.role_user}" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleFg}, ConverterParameter=user}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Nav Items -->
                <StackPanel Grid.Row="2" Spacing="2">
                    <Button Classes="NavBtn Active" Command="{Binding NavigateCommand}" CommandParameter="connect">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚡" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.connect}" Classes="Body" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="8,6"/>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="collect"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📥" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.collect}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="label"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🏷" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.label}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="export"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📋" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.data}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="train"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🧠" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.train}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="8,6"/>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="block">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🛡" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.block}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="blocklist">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📋" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.blocklist}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="NavBtn" Command="{Binding NavigateCommand}" CommandParameter="settings"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="14"/>
                            <TextBlock Text="{DynamicResource nav.settings}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Spacing="10">
                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,4"/>
                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{Binding IsConnected, Converter={x:Static conv:AppConverters.ConnectedColor}}"
                                VerticalAlignment="Center"/>
                        <SelectableTextBlock Text="{Binding ModelInfoText}" FontSize="11"
                                   Foreground="{StaticResource TextHint}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- Language selector -->
                    <ComboBox Name="LangCombo" SelectedIndex="0" FontSize="11"
                              Background="{StaticResource SurfaceBg}" Foreground="{StaticResource TextSecondary}"
                              BorderBrush="{StaticResource BorderColor}"
                              SelectionChanged="LangCombo_SelectionChanged"
                              ItemsSource="{Binding LanguageItems}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:LanguageItem">
                                <TextBlock Text="{Binding Label}" FontSize="12"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Padding="20">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:ConnectViewModel">
                    <views:ConnectView/>
                </DataTemplate>
                <DataTemplate DataType="vm:CollectViewModel">
                    <views:CollectView/>
                </DataTemplate>
                <DataTemplate DataType="vm:LabelViewModel">
                    <views:LabelView/>
                </DataTemplate>
                <DataTemplate DataType="vm:DataViewModel">
                    <views:DataView/>
                </DataTemplate>
                <DataTemplate DataType="vm:TrainViewModel">
                    <views:TrainView/>
                </DataTemplate>
                <DataTemplate DataType="vm:BlockViewModel">
                    <views:BlockView/>
                </DataTemplate>
                <DataTemplate DataType="vm:BlocklistViewModel">
                    <views:BlocklistView/>
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
