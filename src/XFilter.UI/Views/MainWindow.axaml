<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
        xmlns:views="clr-namespace:XFilter.UI.Views"
        xmlns:conv="clr-namespace:XFilter.UI.Converters"
        x:Class="XFilter.UI.Views.MainWindow"
        x:Name="Root"
        Title="x-filter — X Spam Filter"
        Width="900" Height="700"
        MinWidth="800" MinHeight="600"
        Background="#f1f5f9">
    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="220,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#ffffff" BorderBrush="#e2e8f0" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
                <!-- Brand -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="🛡" FontSize="28"/>
                    <TextBlock Text="x-filter" FontSize="20" FontWeight="Bold" Foreground="#0f172a" Margin="0,4,0,0"/>
                    <TextBlock Text="{DynamicResource app.subtitle}" FontSize="11" Foreground="#94a3b8"/>
                </StackPanel>

                <!-- Role Toggle -->
                <Border Grid.Row="1" Background="#f1f5f9" CornerRadius="6" Padding="3" Margin="0,0,0,12">
                    <Grid ColumnDefinitions="*,*">
                        <Border Grid.Column="0" CornerRadius="4" Padding="6,4"
                                Background="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleBgLight}, ConverterParameter=admin}"
                                Cursor="Hand"
                                PointerPressed="RoleToggle_Click" Tag="admin">
                            <TextBlock Text="{DynamicResource app.role_admin}" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleFgLight}, ConverterParameter=admin}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="4" Padding="6,4" Margin="2,0,0,0"
                                Background="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleBgLight}, ConverterParameter=user}"
                                Cursor="Hand"
                                PointerPressed="RoleToggle_Click" Tag="user">
                            <TextBlock Text="{DynamicResource app.role_user}" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding CurrentRole, Converter={x:Static conv:AppConverters.RoleFgLight}, ConverterParameter=user}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Nav Items -->
                <StackPanel Grid.Row="2" Spacing="2">
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="connect">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.connect}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="#e2e8f0" Margin="4,8"/>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="collect"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.collect}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="label"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏷" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.label}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="export"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.data}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="train"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.train}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="#e2e8f0" Margin="4,8"/>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="block">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛡" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.block}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="blocklist">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.blocklist}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="8,6" Background="Transparent"
                            Command="{Binding NavigateCommand}" CommandParameter="settings"
                            IsVisible="{Binding CurrentRole, Converter={x:Static conv:AppConverters.IsAdmin}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource nav.settings}" Foreground="#0f172a" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="3">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{Binding IsConnected, Converter={x:Static conv:AppConverters.ConnectedColor}}"/>
                        <TextBlock Text="{Binding ModelInfoText}" FontSize="10"
                                   Foreground="#64748b" Margin="6,0,0,0"/>
                    </StackPanel>
                    <ComboBox Name="LangCombo" SelectedIndex="0" FontSize="11" Margin="0,8,0,0"
                              Background="#f1f5f9" Foreground="#475569" BorderBrush="#e2e8f0"
                              SelectionChanged="LangCombo_SelectionChanged"
                              ItemsSource="{Binding LanguageItems}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:LanguageItem">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Padding="16">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:ConnectViewModel">
                    <views:ConnectView/>
                </DataTemplate>
                <DataTemplate DataType="vm:CollectViewModel">
                    <views:CollectView/>
                </DataTemplate>
                <DataTemplate DataType="vm:LabelViewModel">
                    <views:LabelView/>
                </DataTemplate>
                <DataTemplate DataType="vm:DataViewModel">
                    <views:DataView/>
                </DataTemplate>
                <DataTemplate DataType="vm:TrainViewModel">
                    <views:TrainView/>
                </DataTemplate>
                <DataTemplate DataType="vm:BlockViewModel">
                    <views:BlockView/>
                </DataTemplate>
                <DataTemplate DataType="vm:BlocklistViewModel">
                    <views:BlocklistView/>
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
