<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.ConnectView"
             x:DataType="vm:ConnectViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <StackPanel Spacing="6">
                <SelectableTextBlock Text="{DynamicResource connect.welcome_title}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <SelectableTextBlock Text="{DynamicResource connect.welcome_desc}" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Border Background="{StaticResource AccentColor}" CornerRadius="14" Padding="8,4">
                        <TextBlock Text="{DynamicResource connect.step1}" FontSize="11" Foreground="White"/>
                    </Border>
                    <TextBlock Text="→" Foreground="{StaticResource TextHint}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BorderColor}" CornerRadius="14" Padding="8,4">
                        <TextBlock Text="{DynamicResource connect.step2}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </Border>
                    <TextBlock Text="→" Foreground="{StaticResource TextHint}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BorderColor}" CornerRadius="14" Padding="8,4">
                        <TextBlock Text="{DynamicResource connect.step3}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </Border>
                    <TextBlock Text="→" Foreground="{StaticResource TextHint}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BorderColor}" CornerRadius="14" Padding="8,4">
                        <TextBlock Text="{DynamicResource connect.step4}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Spacing="12">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="⚡" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource connect.card_title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <SelectableTextBlock Text="{DynamicResource connect.help}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource AccentColor}" CornerRadius="8" Width="16" Height="16">
                                <TextBlock Text="1" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <SelectableTextBlock Text="{DynamicResource connect.guide1}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource AccentColor}" CornerRadius="8" Width="16" Height="16">
                                <TextBlock Text="2" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <SelectableTextBlock Text="{DynamicResource connect.guide2}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <SelectableTextBlock Text="chrome://inspect/#remote-debugging" FontSize="11" Foreground="{StaticResource AccentColor}"/>
                                <SelectableTextBlock Text="{DynamicResource connect.guide2_enter}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource AccentColor}" CornerRadius="8" Width="16" Height="16">
                                <TextBlock Text="3" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <SelectableTextBlock Text="{DynamicResource connect.guide3}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <SelectableTextBlock Text="{DynamicResource connect.guide3_switch}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource AccentColor}" CornerRadius="8" Width="16" Height="16">
                                <TextBlock Text="4" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <SelectableTextBlock Text="{DynamicResource connect.guide4}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <SelectableTextBlock Text="127.0.0.1:9222" FontSize="11" Foreground="{StaticResource AccentColor}"/>
                                <SelectableTextBlock Text="{DynamicResource connect.guide4_click}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel Spacing="4">
                        <SelectableTextBlock Text="{DynamicResource connect.host_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <TextBox Text="{Binding Host}" Width="120"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <SelectableTextBlock Text="{DynamicResource connect.port_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <TextBox Text="{Binding Port}" Width="70"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource connect.btn_connect}" Command="{Binding ConnectCommand}"
                            Classes="Primary"
                            IsEnabled="{Binding IsConnecting, Converter={x:Static conv:AppConverters.Not}}"/>
                    <Button Content="{DynamicResource connect.btn_disconnect}" Command="{Binding DisconnectCommand}"
                            Classes="Outline"
                            IsVisible="{Binding IsConnected}"/>
                </StackPanel>

                <SelectableTextBlock Text="{Binding Status}" Classes="StatusText"
                           Foreground="{Binding IsConnected, Converter={x:Static conv:AppConverters.ConnectedTextColor}}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
