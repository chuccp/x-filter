<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.DataView"
             x:DataType="vm:DataViewModel">
    <Grid RowDefinitions="Auto,*">
        <!-- Header Card -->
        <Border Grid.Row="0" Classes="Card" Padding="16" Margin="0,0,0,16">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center"/>
                        <StackPanel>
                            <SelectableTextBlock Text="{DynamicResource export.title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <SelectableTextBlock Text="{Binding StatsText}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Content="{DynamicResource common.refresh}" Command="{Binding LoadCommand}"
                                Classes="Small Outline"/>
                        <Button Content="{DynamicResource export.btn_copy}" Command="{Binding CopyCsvCommand}"
                                Classes="Small Success"/>
                    </StackPanel>
                </Grid>
                <!-- Filter chips -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="{DynamicResource export.filter_all}" Command="{Binding SetFilterCommand}" CommandParameter="all"
                            Classes="Small Primary"/>
                    <Button Content="{DynamicResource export.filter_spam}" Command="{Binding SetFilterCommand}" CommandParameter="spam"
                            Classes="Small Outline"/>
                    <Button Content="{DynamicResource export.filter_normal}" Command="{Binding SetFilterCommand}" CommandParameter="not-spam"
                            Classes="Small Outline"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- List Card — fills remaining height -->
        <Border Grid.Row="1" Background="{StaticResource CardBg}" CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                Padding="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Comments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,2" Padding="14,12"
                                    Background="{StaticResource CardBg}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <!-- Label badge -->
                                    <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                            CornerRadius="6" Padding="6,4" Margin="0,0,12,0"
                                            Background="{Binding Label, Converter={x:Static conv:AppConverters.LabelColor}}">
                                        <TextBlock Text="{Binding Label, Converter={x:Static conv:AppConverters.LabelBadge}}"
                                                   FontSize="12" Foreground="White" FontWeight="Medium"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Username badge -->
                                    <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Background="{StaticResource AccentLight}" CornerRadius="4" Padding="6,2">
                                            <SelectableTextBlock Text="{Binding Username, StringFormat='@\\{0\\}'}"
                                                       FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Comment text -->
                                    <Border Grid.Column="1" Grid.Row="1" Background="{StaticResource SurfaceBg}"
                                            CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                        <SelectableTextBlock Text="{Binding Text}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                    </Border>

                                    <!-- Post context (smaller, muted) -->
                                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="4"
                                                IsVisible="{Binding PostText, Converter={x:Static conv:AppConverters.NotEmpty}}">
                                        <TextBlock Text="📌" FontSize="10" VerticalAlignment="Center"/>
                                        <SelectableTextBlock Text="{Binding PostText}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="36"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
