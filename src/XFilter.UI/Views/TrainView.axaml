<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.TrainView"
             x:DataType="vm:TrainViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="🧠" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource nav.train}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <SelectableTextBlock Text="{Binding EnvInfo}" Classes="InfoText"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="{DynamicResource train.env_btn_recheck}" Command="{Binding CheckEnvCommand}"
                                    Classes="Small Primary"/>
                            <Button Content="{DynamicResource train.btn_install_deps}" Command="{Binding InstallDepsCommand}"
                                    Classes="Small Success"
                                    IsEnabled="{Binding EnvReady}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="⚡" FontSize="14"/>
                    <SelectableTextBlock Text="{DynamicResource train.training_title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Spacing="4">
                        <SelectableTextBlock Text="{DynamicResource train.epochs_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <TextBox Text="{Binding Epochs}" Width="80"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <SelectableTextBlock Text="{DynamicResource train.batch_size_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <TextBox Text="{Binding BatchSize}" Width="80"/>
                    </StackPanel>
                    <Button Content="{DynamicResource train.btn_train}" Command="{Binding StartTrainingCommand}"
                            Classes="Danger" Width="110" VerticalAlignment="Bottom"
                            IsEnabled="{Binding IsTraining, Converter={x:Static conv:AppConverters.Not}}"/>
                    <Button Content="{DynamicResource common.cancel}" Command="{Binding CancelTrainingCommand}"
                            Classes="Outline" VerticalAlignment="Bottom"
                            IsVisible="{Binding IsTraining}"/>
                </StackPanel>
                <SelectableTextBlock Text="{Binding EpochProgress}" Classes="InfoText" Foreground="{StaticResource AccentColor}"/>
                <SelectableTextBlock Text="{Binding TrainedModelInfo}" Classes="InfoText" Foreground="{StaticResource SuccessColor}"/>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="📜" FontSize="14"/>
                    <SelectableTextBlock Text="{DynamicResource train.log_title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        MinHeight="200" MaxHeight="300">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding Log}" Classes="LogText" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
