<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.CollectView"
             x:DataType="vm:CollectViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <StackPanel Spacing="12">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="📥" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource collect.title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <SelectableTextBlock Text="{DynamicResource collect.url_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Text="{Binding Url}" Watermark="https://x.com/user/status/123"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource collect.btn_start}" Command="{Binding StartCommand}"
                            Classes="Primary"
                            IsEnabled="{Binding IsRunning, Converter={x:Static conv:AppConverters.Not}}"/>
                    <Button Content="{DynamicResource common.cancel}" Command="{Binding CancelCommand}"
                            Classes="Outline"
                            IsVisible="{Binding IsRunning}"/>
                </StackPanel>
                <Border Height="6" Background="{StaticResource BorderColor}" CornerRadius="3" IsVisible="{Binding IsRunning}">
                    <Border Width="{Binding Progress}" Background="{StaticResource AccentColor}" CornerRadius="3"
                            HorizontalAlignment="Left" MinWidth="0"/>
                </Border>
                <SelectableTextBlock Text="{Binding ProgressText}" Classes="StatusText"/>
                <!-- Live comment preview during scraping -->
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="10"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        IsVisible="{Binding IsRunning}" MaxHeight="120">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding LiveComment}" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
                <SelectableTextBlock Text="{Binding Status}" Classes="InfoText" Foreground="{StaticResource TextPrimary}"/>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="📋" FontSize="14"/>
                    <SelectableTextBlock Text="{DynamicResource collect.history_title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <SelectableTextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
