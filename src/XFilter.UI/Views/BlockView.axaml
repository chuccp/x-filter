<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XFilter.UI.ViewModels"
             xmlns:conv="clr-namespace:XFilter.UI.Converters"
             x:Class="XFilter.UI.Views.BlockView"
             x:DataType="vm:BlockViewModel">
    <StackPanel Spacing="16">
        <Border Classes="Card">
            <StackPanel Spacing="12">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="🛡" FontSize="16"/>
                    <SelectableTextBlock Text="{DynamicResource block.title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="8,6"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SelectableTextBlock Text="{Binding ModelInfo}" Classes="StatusText"
                                   VerticalAlignment="Center"/>
                        <Button Content="{DynamicResource block.btn_download_model}"
                                Classes="Small Primary"
                                Command="{Binding DownloadModelCommand}"/>
                        <Button Content="{DynamicResource block.btn_load_model}"
                                Classes="Small Success"
                                Command="{Binding LoadModelCommand}"/>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="4">
                    <SelectableTextBlock Text="{DynamicResource block.url_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Text="{Binding Url}" Watermark="https://x.com/user/status/123"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <SelectableTextBlock Text="{DynamicResource block.threshold_label}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <SelectableTextBlock Text="{Binding Threshold}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto,Auto" Width="300">
                        <Slider Grid.Column="0" Value="{Binding Threshold}"
                                Minimum="0.5" Maximum="0.95" TickFrequency="0.05"/>
                        <SelectableTextBlock Grid.Column="1" Text="{DynamicResource block.threshold_loose}" FontSize="10" Foreground="{StaticResource TextHint}"/>
                        <SelectableTextBlock Grid.Column="2" Text="{DynamicResource block.threshold_strict}" FontSize="10" Foreground="{StaticResource TextHint}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource block.btn_start}" Command="{Binding StartCommand}"
                            Classes="Danger" Width="180"
                            IsEnabled="{Binding IsRunning, Converter={x:Static conv:AppConverters.Not}}"/>
                    <Button Content="{DynamicResource common.cancel}" Command="{Binding CancelCommand}"
                            Classes="Outline"
                            IsVisible="{Binding IsRunning}"/>
                </StackPanel>

                <SelectableTextBlock Text="{Binding Status}" Classes="StatusText"/>
            </StackPanel>
        </Border>

        <Border Classes="Card">
            <StackPanel Spacing="8">
                <StackPanel Classes="SectionTitle">
                    <TextBlock Text="📜" FontSize="14"/>
                    <SelectableTextBlock Text="{DynamicResource block.log_title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <Border Background="{StaticResource SurfaceBg}" CornerRadius="6" Padding="12"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        MinHeight="200" MaxHeight="350">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding Log}" Classes="LogText"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
