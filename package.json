{
  "name": "x-filter",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "node-emoji": "^2.2.0",
    "sql.js": "^1.11.0",
    "ws": "^8.18.2"
  },
  "build": {
    "appId": "com.xfilter.app",
    "productName": "x-filter",
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "src/**/*",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "train.py", "to": "train.py" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": null
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^25.0.0",
    "prettier": "^3.3.1",
    "vite": "^8.0.12",
    "wait-on": "^7.2.0"
  }
}
